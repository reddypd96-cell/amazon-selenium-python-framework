# Copy this file to .env and fill in your values

AMAZON_BASE_URL=https://www.amazon.in
AMAZON_MOBILE_NUMBER=your_mobile_number_here
AMAZON_PASSWORD=your_password_here
SEARCH_TERM=earbuds

# Browser: chrome | firefox | edge
BROWSER=chrome

# Run headless (true/false)
HEADLESS=false

# Safety switch - set to true only when you want to place a real order
PLACE_REAL_ORDER=false
